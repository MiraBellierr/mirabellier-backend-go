### Mirabellier Go Backend — Environment Variables
# Copy this to .env and set your values.

# Port (default: 5000)
PORT=5000

# SQLite database file
DB_FILE=./database.sqlite3

# Session secret (REQUIRED — used to sign auth tokens)
SESSION_SECRET=change-me-to-a-random-string

# Owner Discord IDs (comma-separated)
OWNER_DISCORD_IDS=548050617889980426

# Session cookie config
SESSION_COOKIE_NAME=mirabellier_session
SESSION_COOKIE_MAX_AGE_SECONDS=2592000

# Image storage directory
IMAGES_DIR=images

# Discord OAuth (REQUIRED for login)
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_CALLBACK_URL=http://localhost:5000/auth/discord/callback

# Frontend origin for redirects
FRONTEND_URL=http://localhost:5173

# MyAnimeList (REQUIRED for anime feed)
MAL_CLIENT_ID=your_myanimelist_client_id
MAL_USERNAME=your_myanimelist_username
MAL_ANIME_REFRESH_MINUTES=5

# Discord webhook for QOTD notifications (optional)
QOTD_DISCORD_WEBHOOK_URL=
QOTD_DISCORD_WEBHOOK_USERNAME=Mirabellier QOTD

# Daily quote refresh schedule (UTC, optional)
QUOTE_FETCH_HOUR_UTC=0
QUOTE_FETCH_MINUTE_UTC=0

# Public website base URL (for sitemap, SEO, IndexNow)
WEBSITE_BASE=https://mirabellier.com

# IndexNow (optional)
INDEXNOW_KEY=
INDEXNOW_ENDPOINT=https://api.indexnow.org/indexnow
